   "source": [
    "import numpy as np\n",
    "from glue.core.data import Data\n",
    "from glue_jupyter import JupyterApplication\n",
    "\n",
    "app = JupyterApplication()\n",
    "\n",
    "image = np.random.normal(size=(100, 100))\n",
    "data = Data(label='image', data=image)\n",
    "\n",
    "app.add_data(data)\n",
    "viewer = app.imshow(data='image')\n",
    "\n",
    "app"
   ]
  }
